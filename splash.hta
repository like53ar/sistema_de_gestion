<!DOCTYPE html>
<html>
<head>
<hta:application id="oHTA" 
    applicationname="SabiaLoader" 
    border="none" 
    caption="no" 
    showintaskbar="no" 
    sysmenu="no" 
    scroll="no"
    contextmenu="no"
    singleinstance="yes"/>
<style>
    body {
        background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
        color: #ffffff;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 100%;
        margin: 0;
        padding: 0;
        border: 1px solid #333;
        overflow: hidden;
    }
    .container {
        text-align: center;
        animation: fadeIn 1.5s ease-out;
    }
    h1 {
        font-weight: 700;
        letter-spacing: 8px;
        margin: 0;
        font-size: 42px;
        background: linear-gradient(to right, #ffffff, #8a8a8a);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 0 10px rgba(255,255,255,0.2));
    }
    .divider {
        width: 60px;
        height: 2px;
        background: #8a6a4b;
        margin: 20px auto;
        border-radius: 2px;
    }
    .credits {
        color: #888;
        font-size: 12px;
        letter-spacing: 1px;
        margin-bottom: 25px;
        text-transform: uppercase;
    }
    .status {
        color: #555;
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 15px;
    }
    .loader-container {
        width: 200px;
        height: 2px;
        background: #222;
        border-radius: 2px;
        overflow: hidden;
        margin: 0 auto;
    }
    .loader-bar {
        width: 0%;
        height: 100%;
        background: #8a6a4b;
        animation: progress 5s forwards linear;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @keyframes progress {
        0% { width: 0%; }
        100% { width: 100%; }
    }
</style>
<script>
    // Ajustar tamaño y posición al centro
    var width = 500;
    var height = 300;
    window.resizeTo(width, height);
    window.moveTo((screen.width - width) / 2, (screen.height - height) / 2);
    
    // Cerrar automáticamente después de 6 segundos
    setTimeout(function(){
        window.close();
    }, 6000);
</script>
</head>
<body>
    <div class="container">
        <h1>SABIA</h1>
        <div class="divider"></div>
        <div class="credits">Creado y desarrollado por Fabian A. Correa</div>
        <div class="status">Iniciando Servidores...</div>
        <div class="loader-container">
            <div class="loader-bar"></div>
        </div>
    </div>
</body>
</html>
